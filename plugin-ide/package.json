{
  "name": "saas-workflow-ide-plugin",
  "displayName": "Asisten Joe - AI-Powered Personal Companion",
  "description": "Asisten Joe v5.0: Bertenaga AI sesungguhnya via vscode.lm API. 5 Pilar Kecerdasan: AI Engine, Code Awareness, Contextual Tickets, Persistent Memory, Smart Code Review.",
  "version": "5.0.0",
  "publisher": "joecompanyagent-lab",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Machine Learning"
  ],
  "main": "./extension.js",
  "bin": {
    "saas-workflow-init": "./cli.js"
  },
  "activationEvents": [
    "onView:saasWorkflow.chatView",
    "onCommand:saasWorkflow.openChatTab",
    "onCommand:saasWorkflow.initProject",
    "onCommand:saasWorkflow.createFeatureBranch",
    "onCommand:saasWorkflow.analyzeRisk",
    "onCommand:saasWorkflow.breakdownIdea"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saasWorkflowExplorer",
          "title": "Asisten Joe",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "saasWorkflowExplorer": [
        {
          "type": "webview",
          "id": "saasWorkflow.chatView",
          "name": "Asisten Joe"
        }
      ]
    },
    "commands": [
      {
        "command": "saasWorkflow.openChatTab",
        "title": "Buka Asisten Joe AI Chat",
        "icon": "$(shield)"
      },
      {
        "command": "saasWorkflow.initProject",
        "title": "Asisten Joe: Inisialisasi Cetakan Proyek (Setup Blueprint)"
      },
      {
        "command": "saasWorkflow.createFeatureBranch",
        "title": "Asisten Joe: Buat Ruang Kerja Fitur Baru"
      },
      {
        "command": "saasWorkflow.analyzeRisk",
        "title": "Asisten Joe: Analisis Risiko & Estimasi Biaya"
      },
      {
        "command": "saasWorkflow.breakdownIdea",
        "title": "Asisten Joe: Pecah Ide Bisnis Jadi Tiket Tugas"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "saasWorkflow.openChatTab",
          "icon": "$(shield)",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "start": "node cli.js"
  },
  "dependencies": {}
}
