{
  "name": "saas-workflow-ide-plugin",
  "displayName": "Asisten Joe - GitHub Features Adopted Edition",
  "description": "Asisten Joe v7.0: Adopsi 4 Fitur GitHub Terbaik (GitGuardian 25+ Secret Database, GitLens File Evolution Tracker, Keploy Build Sanity Check, Git-Track Auto CHANGELOG.md).",
  "version": "7.0.0",
  "publisher": "joecompanyagent-lab",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Machine Learning"
  ],
  "main": "./extension.js",
  "bin": {
    "saas-workflow-init": "./cli.js"
  },
  "activationEvents": [
    "onView:saasWorkflow.chatView",
    "onCommand:saasWorkflow.openChatTab",
    "onCommand:saasWorkflow.initProject",
    "onCommand:saasWorkflow.createFeatureBranch",
    "onCommand:saasWorkflow.auditVibeCoding"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saasWorkflowExplorer",
          "title": "Asisten Joe",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "saasWorkflowExplorer": [
        {
          "type": "webview",
          "id": "saasWorkflow.chatView",
          "name": "Asisten Joe"
        }
      ]
    },
    "commands": [
      {
        "command": "saasWorkflow.openChatTab",
        "title": "Buka Asisten Joe AI Chat",
        "icon": "$(shield)"
      },
      {
        "command": "saasWorkflow.auditVibeCoding",
        "title": "Asisten Joe: Audit Kualitas & Keamanan Vibe Coding (Vibe Guard v7.0)"
      },
      {
        "command": "saasWorkflow.initProject",
        "title": "Asisten Joe: Inisialisasi Cetakan Proyek (Setup Blueprint)"
      },
      {
        "command": "saasWorkflow.createFeatureBranch",
        "title": "Asisten Joe: Buat Ruang Kerja Fitur Baru"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "saasWorkflow.openChatTab",
          "icon": "$(shield)",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "start": "node cli.js"
  },
  "dependencies": {}
}
