{
  "name": "saas-workflow-ide-plugin",
  "displayName": "SaaS Branching Blueprint & Governance IDE Plugin",
  "description": "Plugin IDE & AI Chat Copilot Tata Kelola Ruang Kerja SaaS (Dual Mode: Solo & Team)",
  "version": "1.2.0",
  "publisher": "joecompanyagent-lab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "./extension.js",
  "bin": {
    "saas-workflow-init": "./cli.js"
  },
  "activationEvents": [
    "onView:saasWorkflow.chatView",
    "onCommand:saasWorkflow.initProject",
    "onCommand:saasWorkflow.createFeatureBranch"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saasWorkflowExplorer",
          "title": "SaaS Workflow Copilot",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "saasWorkflowExplorer": [
        {
          "type": "webview",
          "id": "saasWorkflow.chatView",
          "name": "Asisten SaaS Copilot"
        }
      ]
    },
    "commands": [
      {
        "command": "saasWorkflow.initProject",
        "title": "SaaS Workflow: Inisialisasi Cetakan Proyek (Setup Blueprint & Protection)"
      },
      {
        "command": "saasWorkflow.createFeatureBranch",
        "title": "SaaS Workflow: Buat Ruang Kerja Fitur Baru (Create Feature Branch)"
      }
    ]
  },
  "scripts": {
    "start": "node cli.js"
  },
  "dependencies": {}
}
