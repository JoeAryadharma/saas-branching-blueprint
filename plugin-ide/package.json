{
  "name": "saas-workflow-ide-plugin",
  "displayName": "Asisten Joe - Personal SaaS Companion",
  "description": "Asisten Joe: Personal IDE Companion Tata Kelola Proyek SaaS, Audit Kelaikan, Rekap CRUD & Visual Diagram",
  "version": "2.0.0",
  "publisher": "joecompanyagent-lab",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "./extension.js",
  "bin": {
    "saas-workflow-init": "./cli.js"
  },
  "activationEvents": [
    "onView:saasWorkflow.chatView",
    "onCommand:saasWorkflow.openChatTab",
    "onCommand:saasWorkflow.initProject",
    "onCommand:saasWorkflow.createFeatureBranch"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saasWorkflowExplorer",
          "title": "Asisten Joe",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "saasWorkflowExplorer": [
        {
          "type": "webview",
          "id": "saasWorkflow.chatView",
          "name": "Asisten Joe"
        }
      ]
    },
    "commands": [
      {
        "command": "saasWorkflow.openChatTab",
        "title": "Buka Asisten Joe AI Chat",
        "icon": "$(shield)"
      },
      {
        "command": "saasWorkflow.initProject",
        "title": "Asisten Joe: Inisialisasi Cetakan Proyek (Setup Blueprint & Protection)"
      },
      {
        "command": "saasWorkflow.createFeatureBranch",
        "title": "Asisten Joe: Buat Ruang Kerja Fitur Baru (Create Feature Branch)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "saasWorkflow.openChatTab",
          "icon": "$(shield)",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "start": "node cli.js"
  },
  "dependencies": {}
}
